# ReLoop AI — Backend env

# Server
PORT=5000
CORS_ORIGINS=http://localhost:5173,https://reloop.ai

# Database (MongoDB Atlas)
MONGO_URI=

# Auth
JWT_SECRET=

# Storage (Cloudflare R2 / S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BASE=

# Google Maps (server-side proxy)
GOOGLE_MAPS_API_KEY=

# AI — leave AI_PROVIDER=mock to run without external keys
AI_PROVIDER=mock              # mock | groq | openai | huggingface
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
HF_TOKEN=
HF_VISION_MODEL=google/vit-base-patch16-224

# Groq API Configuration
GROQ_API_KEY=
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

OCR_PROVIDER=mock             # mock | groq | openai | google
GOOGLE_VISION_KEY=

# Notifications
SENDGRID_API_KEY=
EMAIL_FROM=hello@reloop.ai
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# n8n
N8N_WEBHOOK_BASE=              # e.g. https://n8n.example.com/webhook
N8N_SECRET=

# Certificate rendering (required to generate impact certificates)
CERTIFICATE_SERVICE_URL=
CERTIFICATE_SERVICE_TOKEN=
